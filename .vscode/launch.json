{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug AI Backend",
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/.env",
      "program": "${workspaceFolder}/src/index.js",
      "args": [
        "--env-file=.env"
      ],
      "runtimeArgs": [
        "--watch"
      ],
      "console": "integratedTerminal"
    }
  ]
}